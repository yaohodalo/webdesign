# ============================================
# Environment variables for Vercel
# Set these in Vercel → Project → Settings → Environment Variables
# ============================================

# --- Postgres (auto-injected when you connect Vercel Postgres) ---
# POSTGRES_URL=...
# POSTGRES_PRISMA_URL=...
# POSTGRES_URL_NON_POOLING=...
# POSTGRES_USER=...
# POSTGRES_PASSWORD=...
# POSTGRES_DATABASE=...
# POSTGRES_HOST=...

# --- Admin ---
ADMIN_PASSWORD=change-me-to-a-long-random-string

# --- Email notifications (Resend.com) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
NOTIFY_EMAIL=you@example.com
NOTIFY_FROM=WYJMFOH <onboarding@resend.dev>

# --- Site URL (used in email links) ---
SITE_URL=https://wouldyoujoinmeforonehour.org
